<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/FragmentMain">

    <fragment
        android:id="@+id/FragmentMain"
        android:name="com.rad.iluminus.FragmentMain"
        android:label="@string/first_fragment_label"
        tools:layout="@layout/fragment_main">

        <action
            android:id="@+id/action_FragmentMain_to_FragmentSearchDevice"
            app:destination="@id/FragmentSearchDevice" />
        <action
            android:id="@+id/action_FragmentMain_to_FragmentPermission"
            app:destination="@id/FragmentPermission" />
        <argument
            android:name="enable_fab"
            app:argType="boolean"
            android:defaultValue="false" />
        <action
            android:id="@+id/action_FragmentMain_to_FragmentIluminus"
            app:destination="@id/FragmentIluminus" />
    </fragment>
    <fragment
        android:id="@+id/FragmentSearchDevice"
        android:name="com.rad.iluminus.FragmentSearchDevice"
        android:label="@string/second_fragment_label"
        tools:layout="@layout/fragment_search_device">
        <action
            android:id="@+id/action_FragmentSearchDevice_to_FragmentMain"
            app:destination="@id/FragmentMain" />
        <argument
            android:name="enable_fab"
            app:argType="boolean"
            android:defaultValue="true" />
        <action
            android:id="@+id/action_FragmentSearchDevice_to_FragmentIluminus"
            app:destination="@id/FragmentIluminus" />
    </fragment>

    <fragment
        android:id="@+id/FragmentPermission"
        android:name="com.rad.iluminus.FragmentPermission"
        android:label="@string/second_permission_fragment_label" >
        <action
            android:id="@+id/action_FragmentPermission_to_FragmentMain"
            app:destination="@id/FragmentMain" />
        <argument
            android:name="enable_fab"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <fragment
        android:id="@+id/FragmentIluminus"
        android:name="com.rad.iluminus.FragmentIluminus"
        android:label="@string/fourth_fragment_label" >
        <argument
            android:name="enable_fab"
            app:argType="boolean"
            android:defaultValue="false" />
        <action
            android:id="@+id/action_FragmentIluminus_to_FragmentSearchDevice"
            app:destination="@id/FragmentSearchDevice" />
    </fragment>

</navigation>